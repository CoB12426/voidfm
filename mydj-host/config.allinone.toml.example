[server]
port = 8000
host = "0.0.0.0"

[llm]
# all-in-one compose 内のサービス名を参照
ollama_url = "http://ollama:11434"
default_model = "llama3.2"

[tts]
# all-in-one は fish-speech HTTP を使う
mode = "http"
fish_speech_url = "http://fish-speech:8080"
default_speaker = "default"
# 転送フォーマット: mp3（推奨・軽量）/ wav / opus
audio_format = "mp3"

[dj]
default_language = "en"
default_talk_length = "medium"
