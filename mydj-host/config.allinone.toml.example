[server]
port = 8000
host = "0.0.0.0"

[llm]
# all-in-one compose 内のサービス名を参照
ollama_url = "http://ollama:11434"
default_model = "llama3.2"

[tts]
mode = "subprocess"
s2_binary    = "/app/s2"
s2_model     = "/models/s2-pro-q4_k_m.gguf"
s2_tokenizer = "/app/tokenizer.json"
# 転送フォーマット: mp3（推奨・軽量）/ wav / opus
audio_format = "mp3"

[dj]
default_language = "en"
default_talk_length = "medium"
