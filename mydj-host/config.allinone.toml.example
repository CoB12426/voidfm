[server]
port = 8000
host = "0.0.0.0"

[llm]
# OpenAI-compatible Chat Completions API.
provider = "openai_compatible"
base_url = "https://api.openai.com/v1"
api_key = "env:OPENAI_API_KEY"
default_model = "auto"
temperature = 0.7
max_tokens = 220
# chat_template_kwargs = { enable_thinking = false }

# all-in-one compose で Ollama を使う場合:
# provider = "ollama"
# ollama_url = "http://ollama:11434"
# default_model = "llama3.2"
# keep_alive = "10m"

[tts]
chatterbox_model = "multilingual"
language_id = "en"
cuda_device = 0
audio_format = "wav"
exaggeration = 0.5
cfg_weight = 0.5

[dj]
default_language = "en"
default_talk_length = "medium"
